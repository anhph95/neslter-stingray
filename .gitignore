# ======================
# Ignore everything
# ======================
*

# ======================
# Allow directories we want tracked
# ======================
!src/
!assets/
!dash_data/
!dash_data/misc/

# ======================
# Allow contents of those dirs
# ======================
!src/**
!assets/**
!dash_data/misc/**

# ======================
# Ignore Python cache and build artifacts
# ======================
src/**/__pycache__/
src/**/*.pyc
src/**/*.pyo
src/**/*.pyd
src/**/*.egg-info/

# ======================
# Allow important root project files
# ======================
!dashapp.py
!pyproject.toml
!requirements.txt
!environment.yml
!Dockerfile
!docker-compose.yml
!README.md
!LICENSE
!.gitignore
!.dockerignore
!.gitattributes

# ======================
# Ignore common Python artifacts anywhere
# ======================
__pycache__/
*.pyc
*.pyo
*.pyd
*.pkl

# ======================
# Ignore virtual environments
# ======================
.venv/
venv/
env/

# ======================
# Ignore notebooks
# ======================
*.ipynb
.ipynb_checkpoints/

# ======================
# Ignore logs and temp
# ======================
*.log
.cache/
dash_uploads/

# ======================
# OS / IDE
# ======================
.vscode/
.idea/
.DS_Store
Thumbs.db

# ======================
# Ignore large data and outputs
# ======================
raw_data/
merged_data/
indexes/
media_list/
modified_CAL/
dash_data/data/
old_code/

# ======================
# Ignore calibration / binary data
# ======================
*.CAL
*.mat

# ======================
# Ignore general CSV outputs
# ======================
*.csv

# ======================
# Re-allow small reference CSVs
# ======================
!dash_data/misc/**/*.csv