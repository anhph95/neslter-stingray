# ======================
# Ignore everything
# ======================
*

# ======================
# Allow directories we want tracked
# ======================
!src/
!assets/
!dash_data/
!dash_data/misc/

# Allow contents of those dirs
!src/**
!assets/**
!dash_data/misc/**

# ======================
# Allow important root files
# ======================
!dashapp.py
!pyproject.toml
!requirements.txt
!environment.yml
!Dockerfile
!docker-compose.yml
!README.md
!LICENSE
!.gitignore