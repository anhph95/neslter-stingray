# ======================
# Ignore everything by default
# ======================
*

# ======================
# Allow directories we care about
# ======================
!src/
!assets/
!dash_data/misc/

# Allow contents of those directories
!src/**
!assets/**
!dash_data/misc/**

# ======================
# Allow root project files
# ======================
!README.md
!LICENSE
!.gitignore
!pyproject.toml
!Dockerfile
!docker-compose.yml
!.dockerignore

# ======================
# Python artifacts (still useful inside allowed dirs)
# ======================
__pycache__/
*.pyc
*.pyo
*.pyd
*.pkl
*.egg-info/
build/
dist/

# ======================
# Virtual environments
# ======================
.venv/
venv/
env/

# ======================
# Notebooks
# ======================
*.ipynb
.ipynb_checkpoints/

# ======================
# Logs / cache
# ======================
*.log
.cache/
dash_uploads/

# ======================
# OS / IDE
# ======================
.vscode/
.idea/
.DS_Store
Thumbs.db