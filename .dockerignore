# ======================
# Git
# ======================
.git
.gitignore

# ======================
# Python cache / artifacts
# ======================
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
build/
dist/

# ======================
# Virtual environments
# ======================
.venv/
venv/
env/

# ======================
# Dev / IDE
# ======================
.vscode/
.idea/
.ipynb_checkpoints/
*.ipynb

# ======================
# Logs / temp
# ======================
*.log
*.tmp
*.swp
.cache/
.dash_uploads/

# ======================
# Large data (exclude from build)
# ======================
raw_data/
merged_data/
indexes/
media_list/
modified_CAL/
old_code/

# ======================
# CSV + binary outputs
# ======================
*.csv
*.mat
*.CAL

# ======================
# KEEP runtime-required folders
# ======================
!dash_data/
!dash_data/misc/
!dash_data/misc/**

!assets/
!assets/**

!src/
!src/**

# ======================
# KEEP project config
# ======================
!pyproject.toml
!README.md
!Dockerfile
!docker-compose.yml